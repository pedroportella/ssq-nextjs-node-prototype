{
  "name": "ssq-nextjs-node-prototype",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=22 <23",
    "pnpm": "10.18.3"
  },
  "scripts": {
    "check": "pnpm -r check",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build",
    "test:e2e": "pnpm test:e2e:mock",
    "test:e2e:mock": "SSQ_MOCK_SMOKE_APP=all playwright test -c tests/playwright/mock-smoke.config.ts",
    "test:e2e:mock:dashboard": "SSQ_MOCK_SMOKE_APP=dashboard playwright test -c tests/playwright/mock-smoke.config.ts",
    "test:e2e:mock:seniors-card": "SSQ_MOCK_SMOKE_APP=seniors-card playwright test -c tests/playwright/mock-smoke.config.ts",
    "test:e2e:mock:rental-security-subsidy": "SSQ_MOCK_SMOKE_APP=rental-security-subsidy playwright test -c tests/playwright/mock-smoke.config.ts",
    "test:e2e:mock:headed": "SSQ_MOCK_SMOKE_APP=all playwright test -c tests/playwright/mock-smoke.config.ts --headed --project=chromium --workers=1",
    "test:e2e:mock:rss-dashboard:headed": "SSQ_MOCK_SMOKE_APP=dashboard,rental-security-subsidy playwright test -c tests/playwright/mock-smoke.config.ts tests/mock-smoke/frontend-rss-dashboard-record-flow.spec.ts --headed --project=chromium --workers=1",
    "test:e2e:scenarios": "SSQ_MOCK_SMOKE_APP=all playwright test -c tests/playwright/mock-scenarios.config.ts",
    "test:e2e:scenarios:seniors-card": "SSQ_MOCK_SMOKE_APP=dashboard,seniors-card playwright test -c tests/playwright/mock-scenarios.config.ts",
    "test:e2e:scenarios:rental-security-subsidy": "SSQ_MOCK_SMOKE_APP=dashboard,rental-security-subsidy playwright test -c tests/playwright/mock-scenarios.config.ts",
    "test:e2e:scenarios:headed": "SSQ_MOCK_SMOKE_APP=all playwright test -c tests/playwright/mock-scenarios.config.ts --headed --project=chromium --workers=1",
    "test:e2e:real": "pnpm docker:up:backend && playwright test -c tests/playwright/real-e2e.config.ts --project=chromium --workers=1",
    "test:e2e:real:headed": "pnpm docker:up:backend && playwright test -c tests/playwright/real-e2e.config.ts --headed --project=chromium --workers=1",
    "test:e2e:real:rss-dashboard:headed": "pnpm docker:up:backend && playwright test -c tests/playwright/real-e2e.config.ts tests/e2e/real-backend.spec.ts --headed --project=chromium --workers=1 --grep \"Rental Security Subsidy creates a backend-backed submission\"",
    "test:e2e:report": "playwright show-report",
    "test:full-stack-smoke": "node scripts/full-stack-smoke.mjs",
    "test:reviewer-evidence": "node scripts/reviewer-evidence-smoke.mjs",
    "test:visual": "playwright test -c tests/playwright/visual.config.ts",
    "test:visual:showcase": "SSQ_VISUAL_APP=dashboard playwright test -c tests/playwright/visual.config.ts tests/visual/ui-library-showcase-baselines.spec.ts",
    "test:visual:showcase:update": "SSQ_VISUAL_APP=dashboard playwright test -c tests/playwright/visual.config.ts tests/visual/ui-library-showcase-baselines.spec.ts --update-snapshots",
    "test:visual:update": "playwright test -c tests/playwright/visual.config.ts --update-snapshots",
    "guard:artifacts": "node scripts/quality-guards.mjs artifacts",
    "guard:terminology": "node scripts/quality-guards.mjs terminology",
    "guard:frontend-source": "node scripts/quality-guards.mjs frontend-source",
    "guard:browser-bundles": "node scripts/quality-guards.mjs browser-bundles",
    "guard": "node scripts/quality-guards.mjs all",
    "docker:config": "docker compose config",
    "docker:config:backend": "SSQ_FRONTEND_DATA_SOURCE=backend docker compose config",
    "docker:up": "docker compose up -d postgres backend dashboard seniors-card rental-security-subsidy",
    "docker:up:backend": "SSQ_FRONTEND_DATA_SOURCE=backend docker compose up -d postgres backend dashboard seniors-card rental-security-subsidy",
    "docker:up:core": "docker compose up -d postgres backend",
    "docker:build": "docker compose build backend dashboard seniors-card rental-security-subsidy",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "volta": {
    "node": "22.22.3"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "sass": "1.100.0"
  }
}
