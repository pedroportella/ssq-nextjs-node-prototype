{
  "name": "ssq-nextjs-node-prototype",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=22 <23",
    "pnpm": "10.18.3"
  },
  "scripts": {
    "check": "pnpm -r check",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build",
    "test:mock-smoke": "SSQ_MOCK_SMOKE_APP=dashboard playwright test -c playwright.mock-smoke.config.ts",
    "test:mock-smoke:dashboard": "SSQ_MOCK_SMOKE_APP=dashboard playwright test -c playwright.mock-smoke.config.ts",
    "test:mock-smoke:seniors-card": "SSQ_MOCK_SMOKE_APP=seniors-card playwright test -c playwright.mock-smoke.config.ts",
    "test:mock-smoke:rental-security-subsidy": "SSQ_MOCK_SMOKE_APP=rental-security-subsidy playwright test -c playwright.mock-smoke.config.ts",
    "test:mock-smoke:all": "SSQ_MOCK_SMOKE_APP=all playwright test -c playwright.mock-smoke.config.ts",
    "test:visual": "playwright test -c playwright.visual.config.ts",
    "test:visual:update": "playwright test -c playwright.visual.config.ts --update-snapshots",
    "guard:artifacts": "node scripts/quality-guards.mjs artifacts",
    "guard:frontend-source": "node scripts/quality-guards.mjs frontend-source",
    "guard:browser-bundles": "node scripts/quality-guards.mjs browser-bundles",
    "guard": "node scripts/quality-guards.mjs all",
    "docker:config": "docker compose config",
    "docker:up": "docker compose up -d postgres backend dashboard seniors-card rental-security-subsidy",
    "docker:up:core": "docker compose up -d postgres backend",
    "docker:build": "docker compose build backend dashboard seniors-card rental-security-subsidy",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "volta": {
    "node": "22.22.3"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "sass": "1.100.0"
  }
}
