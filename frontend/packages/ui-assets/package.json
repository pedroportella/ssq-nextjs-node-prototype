{
  "name": "@ssq/ui-assets",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./icons/qld-health-icons-url": "./icons/qld-health-icons-url.ts",
    "./icons/qld-icons-url": "./icons/qld-icons-url.ts",
    "./icons/svg-icons-url": "./icons/svg-icons-url.ts",
    "./icons/*": "./icons/*",
    "./logos/header-logo-qgov-url": "./logos/header-logo-qgov-url.ts",
    "./logos/*": "./logos/*",
    "./fonts/*": "./fonts/*",
    "./images/*": "./images/*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "check": "pnpm typecheck && pnpm test",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
