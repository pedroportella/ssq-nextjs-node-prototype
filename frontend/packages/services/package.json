    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "server-only": "^0.0.1",
    "@ssq/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
