{
  "name": "@ssq/web-components",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "analyse": "lit-analyzer \"src/components/**/*.ts\" --quiet --maxWarnings 0",
    "build": "tsc -p tsconfig.json --noEmit",
    "check": "pnpm typecheck && pnpm test && pnpm analyse && pnpm manifest && pnpm test:browser",
    "lint": "tsc -p tsconfig.json --noEmit",
    "manifest": "cem analyze --litelement --globs \"src/components/**/*.ts\" --exclude \"src/**/*.test.ts\" \"src/**/*.styles.ts\" --outdir . --quiet",
    "test": "vitest run",
    "test:browser": "playwright test -c playwright.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "lit": "^3.3.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@playwright/test": "^1.60.0",
    "@ssq/ui-tokens": "workspace:*",
    "@types/node": "^22.10.2",
    "happy-dom": "^20.10.2",
    "lit-analyzer": "^2.0.3",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vitest": "^2.1.8"
  },
  "customElements": "custom-elements.json"
}
