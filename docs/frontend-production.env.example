# Frontend production runtime example.
# Keep backend/internal URLs server-only. Do not create NEXT_PUBLIC_BACKEND_URL.

NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# Use backend mode for review deployments. Use `mock` only for frontend-only
# demonstration environments that intentionally avoid the backend API.
SSQ_FRONTEND_DATA_SOURCE=backend
BACKEND_INTERNAL_URL=http://backend:7001

DASHBOARD_PUBLIC_URL=https://dashboard.example.qld.gov.au
SENIORS_CARD_PUBLIC_URL=https://seniors-card.example.qld.gov.au
RENTAL_SECURITY_SUBSIDY_PUBLIC_URL=https://rental-security-subsidy.example.qld.gov.au

DASHBOARD_PORT=3000
SENIORS_CARD_PORT=3001
RENTAL_SECURITY_SUBSIDY_PORT=3002
