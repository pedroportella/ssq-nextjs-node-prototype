# Local development defaults.
# Copy to `.env` only when you need to override a value locally.

POSTGRES_DB=ssq_prototype
POSTGRES_USER=ssq_app
POSTGRES_PASSWORD=ssq_dev_password
POSTGRES_PORT=54329

BACKEND_PORT=7001
BACKEND_HOST=0.0.0.0
BACKEND_LOG_LEVEL=info
DATABASE_URL=postgresql://ssq_app:ssq_dev_password@localhost:54329/ssq_prototype

# Frontend runtime mode. Use `mock` for frontend-only work and this prototype's
# current full Compose runtime. Use `backend` only for explicit integration
# checks once the app service adapters for a workflow are implemented.
SSQ_FRONTEND_DATA_SOURCE=mock

DASHBOARD_PORT=3000
SENIORS_CARD_PORT=3001
RENTAL_SECURITY_SUBSIDY_PORT=3002

DASHBOARD_PUBLIC_URL=http://localhost:3000
SENIORS_CARD_PUBLIC_URL=http://localhost:3001
RENTAL_SECURITY_SUBSIDY_PUBLIC_URL=http://localhost:3002
